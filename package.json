{
  "name": "@emillc/eden",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "author": {
    "name": "ChillCicada",
    "url": "https://chillcicada.com",
    "email": "2210227279@qq.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --port=5555",
    "build": "astro check && astro build",
    "preview": "astro preview --port=4444",
    "test": "vitest run",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "astro:up": "npx @astrojs/upgrade",
    "lint": "eslint .",
    "cz": "cz",
    "lint:fix": "eslint --fix .",
    "fontmin": "node ./scripts/fontmin",
    "jampack": "jampack ./dist",
    "postinstall": "simple-git-hooks",
    "postbuild": "node ./scripts/fontmin && jampack ./dist && node ./scripts/postbuild"
  },
  "dependencies": {
    "@iconify-json/mingcute": "1.2.1",
    "@iconify-json/ri": "1.2.1",
    "fuse.js": "7.0.0",
    "remark-collapse": "0.1.2",
    "remark-toc": "9.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "2.27.3",
    "@astrojs/check": "0.9.4",
    "@astrojs/rss": "4.0.8",
    "@astrojs/sitemap": "3.2.0",
    "@astrojs/svelte": "5.7.2",
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@divriots/jampack": "0.28.0",
    "@types/html-minifier": "4.0.5",
    "@types/node": "22.7.5",
    "@unocss/eslint-plugin": "0.63.4",
    "astro": "4.16.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.12.0",
    "eslint-plugin-astro": "1.2.4",
    "eslint-plugin-format": "0.1.2",
    "eslint-plugin-svelte": "2.44.1",
    "fontmin": "1.1.0",
    "github-slugger": "2.0.0",
    "html-minifier": "4.0.0",
    "lightningcss": "1.27.0",
    "lint-staged": "15.2.10",
    "simple-git-hooks": "2.11.1",
    "terser": "5.34.1",
    "typescript": "5.6.3",
    "typstyle": "0.11.35",
    "unocss": "0.63.4",
    "vitest": "2.1.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx commitlint -e $1"
  },
  "lint-staged": {
    "*.{[jt]s,json,y{,a}ml,astro,css,svelte,md}": [
      "eslint --fix"
    ],
    "*.typ": "typstyle -i"
  },
  "jampack": {}
}
